{
  "name": "productivity-tracker",
  "version": "1.0.0",
  "description": "30-day productivity tick game with monthly history",
  "main": "server/index.js",
  "scripts": {
    "start":       "node server/index.js",
    "server":      "nodemon server/index.js",
    "client":      "cd client && npm run dev",
    "dev":         "concurrently \"npm run server\" \"npm run client\"",
    "build":       "cd client && npm run build",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "bcryptjs":   "^2.4.3",
    "cors":       "^2.8.5",
    "dotenv":     "^16.4.5",
    "express":    "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose":   "^8.4.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon":      "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
