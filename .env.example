# MongoDB Atlas — include the database name after the cluster URL
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/productivity-tracker?retryWrites=true&w=majority&appName=Cluster0

# JWT secret — use a long random string in production
JWT_SECRET=replace_with_a_very_long_random_secret

# Port (Render sets this automatically; omit from Render env vars)
PORT=5000

# Frontend origin for CORS
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173
